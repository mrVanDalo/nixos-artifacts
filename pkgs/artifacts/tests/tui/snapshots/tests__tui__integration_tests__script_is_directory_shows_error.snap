---
source: tests/tui/integration_tests.rs
expression: "run_tui(\"scenarios/error-script-is-directory\", events)"
---
TestResult {
    events: [
        "quit",
    ],
    before: ModelState {
        screen: "ArtifactList",
        selected_index: 0,
        artifacts: [
            ArtifactState {
                target: "machine-name",
                name: "test-artifact",
                status: "Pending",
            },
        ],
        error: None,
    },
    after: ModelState {
        screen: "ArtifactList",
        selected_index: 0,
        artifacts: [
            ArtifactState {
                target: "machine-name",
                name: "test-artifact",
                status: "Failed(\"backend 'test' step 'check_serialization': '[PROJECT]/examples/scenarios/error-script-is-directory/./check.sh' is not a file\")",
            },
        ],
        error: None,
    },
}
