---
source: tests/tui/integration_tests.rs
expression: "run_tui(\"scenarios/single-artifact-with-prompts\", events)"
---
TestResult {
    events: [
        "select",
        "fill_prompts([\"secret-one\", \"secret-two\"])",
        "quit",
    ],
    before: ModelState {
        screen: "ArtifactList",
        selected_index: 0,
        artifacts: [
            ArtifactState {
                target: "machine-name",
                name: "test-artifact",
                status: "Pending",
            },
        ],
        error: None,
    },
    after: ModelState {
        screen: "Generating",
        selected_index: 0,
        artifacts: [
            ArtifactState {
                target: "machine-name",
                name: "test-artifact",
                status: "Pending",
            },
        ],
        error: None,
    },
    serialized_artifacts: {},
}
