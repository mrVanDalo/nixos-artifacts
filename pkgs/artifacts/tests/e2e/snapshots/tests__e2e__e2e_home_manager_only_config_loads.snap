---
source: tests/e2e/mod.rs
expression: make_config
---
MakeConfiguration {
    nixos_map: {},
    home_map: {
        "test-user": {
            "home-config": ArtifactDef {
                name: "home-config",
                description: None,
                shared: false,
                files: {
                    "app-config": FileDef {
                        name: "app-config",
                        path: Some(
                            "${XDG_RUNTIME_DIR}/artifacts/home-config/app-config",
                        ),
                        owner: None,
                        group: None,
                    },
                },
                prompts: {},
                generator: "/nix/store/HASH-test_generator_config.sh",
                serialization: "test",
            },
            "home-secret": ArtifactDef {
                name: "home-secret",
                description: None,
                shared: false,
                files: {
                    "secret-file": FileDef {
                        name: "secret-file",
                        path: Some(
                            "${XDG_RUNTIME_DIR}/artifacts/home-secret/secret-file",
                        ),
                        owner: None,
                        group: None,
                    },
                },
                prompts: {},
                generator: "/nix/store/HASH-test_generator_home.sh",
                serialization: "test",
            },
        },
    },
    nixos_config: {},
    home_config: {},
    make_base: "/nix/store",
    make_json: "/nix/store/HASH-test.json",
}
