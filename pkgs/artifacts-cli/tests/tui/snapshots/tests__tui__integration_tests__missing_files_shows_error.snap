---
source: tests/tui/integration_tests.rs
expression: "run_tui(\"missing-files\", events)"
---
TestResult {
    before: ModelState {
        screen: "ArtifactList",
        selected_index: 0,
        artifacts: [
            ArtifactState {
                target: "missing-files",
                name: "test-artifact",
                status: "Pending",
            },
        ],
        error: None,
    },
    after: ModelState {
        screen: "ArtifactList",
        selected_index: 0,
        artifacts: [
            ArtifactState {
                target: "missing-files",
                name: "test-artifact",
                status: "Failed(\"generator missing required files for artifact 'test-artifact': [very-simple-secrets]\")",
            },
        ],
        error: None,
    },
}
